{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/deepseek-v4-flash"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ],
      "temperature": 0.2,
    },
    "sisyphus-junior": {
      "model": "opencode-go/deepseek-v4-pro",
      "thinking": {
 	 "type": "disabled"
	},
      "fallback_models": [
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/deepseek-v4-flash"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ],
      "temperature": 0.2,
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/deepseek-v4-flash"
        }
      ],
      "temperature": 0.15,
    },
    "prometheus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "openai/gpt-5.5"
        }
      ],
      "temperature": 0.15,
    },
    "metis": {
      "model": "opencode-go/glm-5.1",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        }
      ],
      "temperature": 0.15,
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ],
      "temperature": 0.1,
      "reasoningEffort": "high",
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ],
      "temperature": 0.1,
      "reasoningEffort": "high",
    },
    "librarian": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        }
      ],
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": "ask",
        "webfetch": "allow"
      },
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        }
      ],
      "temperature": 0.2,
      "permission": {
        "edit": "deny",
        "bash": "ask"
      },
    }
  },
  "categories": {
    "quick": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        }
      ]
    },
    "unspecified-low": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        }
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ]
    },
    "deep": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        {
          "model": "deepseek-official/deepseek-v4-pro"
        }
      ]
    },
    "architecture": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ]
    },
    "tests": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/deepseek-v4-flash"
        }
      ]
    },
    "writing": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        }
      ]
    },
    "visual-engineering": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        {
          "model": "opencode-go/glm-5.1"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        }
      ]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "fallback_models": [
        {
          "model": "opencode-go/deepseek-v4-pro"
        },
        {
          "model": "deepseek-official/deepseek-v4-pro"
        },
        {
          "model": "opencode-go/glm-5.1"
        }
      ]
    }
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [408, 429, 500, 502, 503, 504],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 15,
    "timeout_seconds": 60
  },
  "background_task": {
    "defaultConcurrency": 12,
    "providerConcurrency": {
      "opencode-go": 12,
      "deepseek-official": 6,
      "openai": 6
    },
    "modelConcurrency": {
      "opencode-go/deepseek-v4-flash": 12,
      "opencode-go/deepseek-v4-pro": 12,
      "opencode-go/glm-5.1": 6,
      "deepseek-official/deepseek-v4-pro": 6,
      "openai/gpt-5.5": 6
    }
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
}
